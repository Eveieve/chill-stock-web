<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.chilluminati.chillstock.example.repository.ExampleRepository">


    <insert id="insert" parameterType="com.chilluminati.chillstock.example.dto.UserDtoExam">
        INSERT INTO user_tbl (username, password, grantUser)
        VALUES (#{username}, #{password}, #{grantUser})
    </insert>

    <select id="getByUserId" parameterType="string" resultType="com.chilluminati.chillstock.example.dto.UserDtoExam">
        SELECT username, password, grantUser
        FROM user_tbl
        WHERE username = #{userId}
    </select>

    <select id="getAll" resultType="com.chilluminati.chillstock.example.dto.UserDtoExam">
        SELECT username, password, grantUser
        FROM user_tbl
    </select>

    <select id = "deleteByUserId" parameterType="string" resultType="com.chilluminati.chillstock.example.dto.UserDtoExam">
        DELETE FROM user_tbl
        WHERE username = #{userId}

    </select>

</mapper>